{
  "name": "olvid-nextcloud",
  "version": "0.0.0-alpha.4",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": "^22.0.0",
    "npm": "^10.5.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite --mode development build",
    "watch": "vite --mode development build --watch",
    "lint": "eslint src",
    "stylelint": "stylelint src/**/*.vue src/**/*.scss src/**/*.css",
    "l10n:auto": "npm run l10n:extract && npm run l10n:translate && npm run l10n:generate",
    "l10n:extract": "./translation/scripts/1_extract.sh",
    "l10n:translate": "./translation/scripts/2_translate.sh",
    "l10n:generate": "./translation/scripts/3_convert.sh"
  },
  "type": "module",
  "browserslist": [
    "extends @nextcloud/browserslist-config"
  ],
  "dependencies": {
    "@nextcloud/auth": "^2.6.0",
    "@nextcloud/axios": "^2.6.0",
    "@nextcloud/dialogs": "^7.4.0",
    "@nextcloud/event-bus": "^3.3.3",
    "@nextcloud/router": "^3.1.0",
    "@nextcloud/vue": "^8.29.2",
    "qrcode": "^1.5.4",
    "vue": "^2.7.16",
    "vue-material-design-icons": "^5.3.1",
    "vue-router": "^3.6.5"
  },
  "devDependencies": {
    "@nextcloud/browserslist-config": "^3.0.1",
    "@nextcloud/eslint-config": "^8.4.2",
    "@nextcloud/stylelint-config": "^3.1.0",
    "@nextcloud/vite-config": "^1.5.2",
    "vite": "^7.1.3"
  }
}
