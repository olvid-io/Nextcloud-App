{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["DOM", "ESNext"],
		"allowJs": true,
		"allowSyntheticDefaultImports": true,
		"resolveJsonModule": true,
		"strict": false,
		"noImplicitAny": false
	},
	"include": ["src/**/*.ts", "src/**/*.vue"],
	"exclude": ["node_modules"]
}
